{
  "manifest_version": 2,
  "name": "OSMail Theme",
  "version": "1.1.0",
  "description": "OSMail branded theme for Thunderbird",
  "browser_specific_settings": {
    "gecko": {
      "id": "osmail-theme@osmail.ca",
      "strict_min_version": "140.0"
    }
  },
  "theme": {
    "colors": {
      "frame": "#1A1A2E",
      "frame_inactive": "#252540",
      "tab_background_text": "#A78BFA",
      "tab_selected": "#7C3AED",
      "tab_text": "#FFFFFF",
      "tab_line": "#7C3AED",
      "tab_loading": "#A78BFA",
      "tab_background_separator": "#2D2D4A",
      "toolbar": "#1A1A2E",
      "toolbar_text": "#F4F4F6",
      "toolbar_field": "#2D2D4A",
      "toolbar_field_text": "#F4F4F6",
      "toolbar_field_border": "#6B6B7B",
      "toolbar_field_focus": "#FFFFFF",
      "toolbar_field_text_focus": "#1A1A2E",
      "toolbar_field_border_focus": "#7C3AED",
      "toolbar_field_highlight": "#7C3AED",
      "toolbar_field_highlight_text": "#FFFFFF",
      "toolbar_top_separator": "transparent",
      "toolbar_bottom_separator": "#4C1D95",
      "toolbar_vertical_separator": "#6B6B7B",
      "button_background_hover": "#EDE9FD",
      "button_background_active": "#4C1D95",
      "sidebar": "#1A1A2E",
      "sidebar_text": "#D1D1D8",
      "sidebar_highlight": "#7C3AED",
      "sidebar_highlight_text": "#FFFFFF",
      "sidebar_highlight_border": "#A78BFA",
      "sidebar_border": "#4C1D95",
      "popup": "#1A1A2E",
      "popup_text": "#F4F4F6",
      "popup_border": "#4C1D95",
      "popup_highlight": "#7C3AED",
      "popup_highlight_text": "#FFFFFF",
      "icons": "#A78BFA",
      "icons_attention": "#7C3AED"
    }
  }
}
