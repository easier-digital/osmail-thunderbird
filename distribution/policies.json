{
  "_comment": "OSMail enterprise policies for Thunderbird",
  "policies": {
    "DisableAppUpdate": true,
    "AppUpdateURL": "https://github.com/easier-digital/osmail-thunderbird/releases",
    "DisableTelemetry": true,
    "OfferToSaveLogins": false,
    "PasswordManagerEnabled": false,
    "ExtensionSettings": {
      "osmail-theme@osmail.ca": {
        "installation_mode": "force_installed",
        "install_url": "https://github.com/easier-digital/osmail-thunderbird/releases/latest/download/osmail-theme.xpi"
      },
      "thunderbird-custom-idp@raa": {
        "installation_mode": "blocked"
      },
      "osmail-onboarding@osmail.ca": {
        "installation_mode": "force_installed",
        "install_url": "https://github.com/easier-digital/osmail-thunderbird/releases/latest/download/osmail-onboarding.xpi"
      }
    },
    "Preferences": {
      "mail.phishing.detection.enabled": {
        "Value": true,
        "Status": "locked"
      },
      "toolkit.legacyUserProfileCustomizations.stylesheets": {
        "Value": false,
        "Status": "locked"
      }
    }
  }
}
