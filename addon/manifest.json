{
  "manifest_version": 2,
  "name": "OSMail Onboarding",
  "version": "1.0.0",
  "description": "OSMail onboarding wizard — configures email, calendar, and contacts automatically.",
  "browser_specific_settings": {
    "gecko": {
      "id": "osmail-onboarding@osmail.ca",
      "strict_min_version": "140.0"
    }
  },
  "permissions": [
    "addressBooks",
    "accountsRead",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "64": "icons/icon-64.png"
  },
  "experiment_apis": {
    "osmail": {
      "schema": "experiments/osmail/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["osmail"]],
        "script": "experiments/osmail/implementation.js"
      }
    }
  }
}
